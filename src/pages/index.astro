---
const clubs = [
  { name: "Grujoan", code: 175 },
  { name: "Centro Asturiano", code: 180 },
  { name: "Covadonga", code: 190 },
  { name: "La Carisa", code: 195 },
  { name: "Oviedo", code: 200 },
  { name: "Juventud Estadio", code: 150 },
  { name: "Astur", code: 170 }
];
---

<h1>Buscar club</h1>

<select id="clubSelect">
  <option value="">Selecciona un club</option>

  {clubs.map((club) => (
    <option value={club.code}>{club.name}</option>
  ))}
</select>

<button id="buscarBtn">Buscar</button>

<pre id="resultado"></pre>

<script>
  const btn = document.getElementById("buscarBtn");
  const select = document.getElementById("clubSelect");
  const resultado = document.getElementById("resultado");

  btn?.addEventListener("click", async () => {
    const clubCode = select?.value;

    if (!clubCode) {
      resultado.textContent = "Selecciona un club primero";
      return;
    }

    try {
      // Cambia esta URL por tu API
      const response = await fetch(`https://apihq.azzulei.com/v1/games?status=finished&club_id=${clubCode}`);

      if (!response.ok) {
        throw new Error("Error en la petición");
      }

      const data = await response.json();

      resultado.textContent = JSON.stringify(data, null, 2);
    } catch (error) {
      resultado.textContent = "Error: " + error.message;
    }
  });
</script>