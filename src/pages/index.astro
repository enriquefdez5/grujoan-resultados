---
import ClubSelector from "../components/ClubSelector.astro";
import AgeTabs from "../components/AgeTabs.astro";
import TeamsList from "../components/TeamsList.astro";
import GamesList from "../components/GamesList.astro";

import "../styles/global.css";
---
<head>
    <title>Buscador de partidos de fútbol</title>
    <meta property="og:title" content="Buscador de partidos de fútbol HQSport.plus">
    <meta property="og:description" content="Herramienta para buscar enlaces de partidos grabados y publicados en HQSport.plus">
    <meta property="og:image" content="https://grujoan-partidos.vercel.app/link_image.png">
    <meta property="og:url" content="https://grujoan-partidos.vercel.app/">
    <meta property="og:type" content="website">
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<div class="min-h-screen bg-gray-50 py-6 sm:py-10">

  <div class="w-full max-w-3xl mx-auto px-3 sm:px-6 lg:px-8 space-y-8">

    <h1 class="text-2xl sm:text-3xl font-bold text-center text-gray-800">
      Partidos del club
    </h1>

    <ClubSelector />

    <hr>

    <div id="loading" class="hidden flex justify-center py-8">
        <div class="flex items-center gap-3 text-gray-600">
            
            <div class="w-6 h-6 border-4 border-gray-200 border-t-blue-600 rounded-full animate-spin"></div>
            
            <span class="text-sm sm:text-base font-medium">Cargando partidos...</span>
        
        </div>
    </div>

    <AgeTabs />
    <TeamsList />
    <GamesList />
  </div>
</div>  

<script src="../scripts/main.ts"></script>
